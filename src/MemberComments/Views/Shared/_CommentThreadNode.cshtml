@using MemberComments.Controllers
@using MemberComments.Models
@using MemberComments.ViewModels
@model CommentNodeVm
@{
    CommentThreadNode row = Model.Node;
    MemberCommentsViewModel pageVm = Model.Page;
    var c = row.Comment;

    var tz = TimeZoneInfo.FindSystemTimeZoneById("Australia/Sydney");
}
<li class="member-comments__item" id="comment-@c.Id">
    <div class="member-comments__meta">
        <strong class="member-comments__author">@c.AuthorName</strong>
        @if (c.IsDeleted && c.DeletedUtc.HasValue)
        {
            <time datetime="@c.DeletedUtc.Value.ToString("o")" class="member-comments__time">Deleted at @TimeZoneInfo.ConvertTime(c.DeletedUtc.Value.LocalDateTime, tz).ToString("yyyy-MM-dd h:mm:ss tt")</time>
        }
        else if (c.EditedUtc.HasValue)
        {
            <time datetime="@c.EditedUtc.Value.ToString("o")" class="member-comments__time">@(c.IsModeratorAttributedEdit ? "Edited by moderator at " : "Edited at ")@TimeZoneInfo.ConvertTime(c.EditedUtc.Value.LocalDateTime, tz).ToString("yyyy-MM-dd h:mm:ss tt")</time>
        }
        else
        {
            <time datetime="@c.CreatedUtc.ToString("o")" class="member-comments__time">@TimeZoneInfo.ConvertTime(c.CreatedUtc.LocalDateTime, tz).ToString("yyyy-MM-dd h:mm:ss tt")</time>
        }
        <a href="#comment-@c.Id" class="member-comments__link">Link</a>
    </div>
    @if (c.IsDeleted is false && string.IsNullOrEmpty(c.Subject) is false)
    {
        <p class="member-comments__subject">@c.Subject</p>
    }
    @if (c.IsDeleted)
    {
        <div class="member-comments__body">@c.Text</div>
    }
    else
    {
        <div class="member-comments__body member-comments__body--html">@Html.Raw(c.Text)</div>
    }

    @if (pageVm.CanPost && c.IsDeleted is false && c.MemberKey != pageVm.CurrentMemberKey)
    {
        <details class="member-comments__reply">
            <summary>Reply</summary>
            @using (Html.BeginUmbracoForm<CommentsSurfaceController>(nameof(CommentsSurfaceController.Create), FormMethod.Post))
            {
                <input type="hidden" name="@nameof(CreateCommentForm.ContentKey)" value="@pageVm.ContentKey" />
                <input type="hidden" name="@nameof(CreateCommentForm.ParentId)" value="@c.Id" />
                <label class="member-comments__label" for="reply-@c.Id">Your reply</label>
                <textarea id="reply-@c.Id" name="@nameof(CreateCommentForm.Text)" rows="10" class="member-comments__textarea member-comments__richtext"></textarea>
                <button type="submit" class="member-comments__submit">Reply</button>
            }
        </details>
    }

    @{
        var canEdit = pageVm.CurrentMemberKey is Guid mk && c.IsDeleted is false && (mk == c.MemberKey || pageVm.IsModerator);
    }
    @if (canEdit)
    {
        <details class="member-comments__edit">
            <summary>Edit</summary>
            <div class="member-comments__edit-actions">
                @using (Html.BeginUmbracoForm<CommentsSurfaceController>(nameof(CommentsSurfaceController.Edit), FormMethod.Post))
                {
                    <input type="hidden" name="@nameof(EditCommentForm.ContentKey)" value="@pageVm.ContentKey" />
                    <input type="hidden" name="@nameof(EditCommentForm.CommentId)" value="@c.Id" />
                    @if (c.ParentId is null)
                    {
                        <label class="member-comments__label" for="edit-subject-@c.Id">Subject <span class="member-comments__optional">(optional)</span></label>
                        <input type="text" id="edit-subject-@c.Id" name="@nameof(EditCommentForm.Subject)" value="@c.Subject" maxlength="256" class="member-comments__input" autocomplete="off" />
                    }
                    <label class="member-comments__label" for="edit-@c.Id">Edit comment</label>
                    <textarea id="edit-@c.Id" name="@nameof(EditCommentForm.Text)" rows="10" class="member-comments__textarea member-comments__richtext">@Html.Raw(c.Text)</textarea>
                    <button type="submit" class="member-comments__submit">Save changes</button>
                }
                @using (Html.BeginUmbracoForm<CommentsSurfaceController>(nameof(CommentsSurfaceController.Delete), FormMethod.Post))
                {
                    <input type="hidden" name="@nameof(DeleteCommentForm.ContentKey)" value="@pageVm.ContentKey" />
                    <input type="hidden" name="@nameof(DeleteCommentForm.CommentId)" value="@c.Id" />
                    <button type="submit" class="member-comments__submit member-comments__submit--delete" onclick="return confirm('Delete this comment?');">Delete</button>
                }
            </div>
        </details>
    }

    @if (row.Children.Count > 0)
    {
        <ul class="member-comments__list member-comments__list--replies">
            @foreach (CommentThreadNode child in row.Children)
            {
                <partial name="_CommentThreadNode" model="new CommentNodeVm { Node = child, Page = pageVm }" />
            }
        </ul>
    }
</li>
